#include <stdio.h>

int main(void) {
  float nota1, nota2, resultado;
  printf("Digite a primeira nota: ");
  scanf("%f", &nota1);
  printf("Digite a segunda nota: ");
  scanf("%f", &nota2);
  resultado = (nota1 + nota2) / 2;
  if (resultado >= 7){
    printf("Aprovado\n");
  }
  else{
    printf("Reprovado\n");
  }
  return 0;
}
