#include <stdio.h>
int main(){
   int num1, num2;
   printf("Digite um numero: ");
   scanf("%i", &num1);
   printf("Digite outro numero: ");
   scanf("%i", &num2);
   if (num1 > num2){
      printf("O maior numero é: %i\n", num1);
   }
   else if (num2 > num1){
      printf("O maior numero é: %i\n", num2);
   }
   else{
      printf("Os numeros são iguais: %i\n", num2);
   }
  return 0;
}
