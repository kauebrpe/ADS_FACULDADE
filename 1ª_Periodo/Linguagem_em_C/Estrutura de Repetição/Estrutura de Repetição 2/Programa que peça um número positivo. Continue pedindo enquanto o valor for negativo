#include <stdio.h>

int main() {
    int numero;
    printf("Digite um numero positivo: ");
    scanf("%d", &numero);
    
    while (numero < 0){
        printf("Valor invalido! Digite novamente: ");
        scanf("%d", &numero);
    }
    printf("Numero valido digitado: %d\n", numero);

    return 0;
}
