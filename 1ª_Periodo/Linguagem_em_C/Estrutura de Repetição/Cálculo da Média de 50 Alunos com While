#include <stdio.h>

int main() {
    int i = 1, nota;
    float soma = 0, media;

    while (i <= 50) {
        printf("Nota do aluno %d: ", i);
        scanf("%d", &nota);
        soma += nota;
        i++;
    }

    media = soma / 50;
    printf("Media: %.2f\n", media);

    return 0;
}

