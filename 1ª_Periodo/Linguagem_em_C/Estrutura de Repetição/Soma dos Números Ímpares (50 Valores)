#include <stdio.h>

int main() {
    int i, num, soma = 0;

    for (i = 1; i <= 50; i++) {
        printf("Digite o %dº numero: ", i);
        scanf("%d", &num);
        if (num % 2 && num != 0) {
            soma += num;
        }
    }

    printf("Soma dos impares: %d\n", soma);
    return 0;
}
