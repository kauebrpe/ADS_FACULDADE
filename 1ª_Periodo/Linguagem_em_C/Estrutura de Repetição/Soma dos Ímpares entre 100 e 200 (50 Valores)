#include <stdio.h>

int main() {
    int i, num, soma = 0;

    for (i = 1; i <= 5; i++) {
        printf("Digite o %dº numero: ", i);
        scanf("%d", &num);

        if (num >= 100 && num <= 200 && num % 2 != 0) {
            soma += num;
        }
    }

    printf("Soma dos numeros impares entre 100 e 200: %d\n", soma);
    return 0;
}
